<Window x:Class="EdeboCsvProcessor.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ЄДЕБО CSV Processor" Height="768" Width="1024"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F8"
        FontFamily="Segoe UI">
    <Window.Resources>
        <ContextMenu x:Key="ColumnHeaderContextMenu">
            <MenuItem Header="Сховати стовпець" Click="HideColumn_Click"/>
        </ContextMenu>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Обробка заяв з ЄДЕБО" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="💸 Підтримати розробника" Padding="10,5" Background="#F1C40F" Foreground="#2C3E50" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="DonateButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- Files Selection -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect Color="#E0E0E0" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Вхідний файл:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox x:Name="InputFileTextBox" Grid.Column="1" Margin="10,0" Padding="5" IsReadOnly="True" ToolTip="Оберіть файл .csv або .xlsx"/>
                <Button Content="Відкрити..." Grid.Column="2" Padding="5" Click="BrowseInputFile_Click" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
            </Grid>
        </Border>

        <!-- Filters & Search Toolbar -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect Color="#E0E0E0" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔍 Пошук (текст):" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,5,0"/>
                    <TextBox x:Name="SearchTextBox" Width="120" Padding="5" TextChanged="FilterChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="15,0,0,0">
                    <TextBlock Text="Статус:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,5,0"/>
                    <ComboBox x:Name="StatusComboBox" Width="120" Padding="3" SelectionChanged="FilterChanged" IsEditable="True"/>
                    <TextBlock Text="Пропозиція:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="10,0,5,0"/>
                    <ComboBox x:Name="ProposalComboBox" Width="140" Padding="3" SelectionChanged="FilterChanged" IsEditable="True"/>
                    <TextBlock Text="Бюджет:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="10,0,5,0"/>
                    <ComboBox x:Name="BudgetComboBox" Width="70" Padding="3" SelectionChanged="FilterChanged">
                        <ComboBoxItem Content="Всі" IsSelected="True"/>
                        <ComboBoxItem Content="Так"/>
                        <ComboBoxItem Content="Ні"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="15,0,0,0">
                    <TextBlock Text="Дата З:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <DatePicker x:Name="DateFromPicker" Width="100" SelectedDateChanged="FilterChanged"/>
                    <TextBlock Text="Дата По:" VerticalAlignment="Center" Margin="5,0,5,0"/>
                    <DatePicker x:Name="DateToPicker" Width="100" SelectedDateChanged="FilterChanged"/>
                </StackPanel>

                <Button Grid.Column="3" Content="Очистити" Margin="10,0,0,0" Padding="10,5" Click="ClearFilters_Click" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Data Grid -->
        <DataGrid x:Name="ApplicationsDataGrid" Grid.Row="3" Margin="0,0,0,15" 
                  AutoGenerateColumns="False" CanUserReorderColumns="True"
                  IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False" 
                  AlternatingRowBackground="#F9F9F9" GridLinesVisibility="Horizontal" 
                  BorderBrush="#E0E0E0" BorderThickness="1">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="5"/>
                    <Setter Property="Background" Value="#EAEDED"/>
                    <Setter Property="BorderBrush" Value="#D5D8DC"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="ContextMenu" Value="{StaticResource ColumnHeaderContextMenu}"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
        </DataGrid>

        <!-- Export & Status -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock x:Name="StatusTextBlock" Text="Готово до роботи. Відкрийте файл для перегляду." VerticalAlignment="Center" Foreground="#7F8C8D" TextWrapping="Wrap"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="StatisticsButton" Content="📊 Статистика" FontSize="16" FontWeight="Bold" Margin="0,0,10,0"
                        Padding="20,10" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand" Click="StatisticsButton_Click"
                        IsEnabled="False">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#BDC3C7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                
                <Button x:Name="ExportButton" Content="Експортувати в Excel" FontSize="16" FontWeight="Bold" 
                        Padding="20,10" Background="#2ECC71" Foreground="White" BorderThickness="0" Cursor="Hand" Click="ExportButton_Click"
                        IsEnabled="False">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#BDC3C7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Update Status Panel -->
        <Grid Grid.Row="4" Margin="0,15,0,0" x:Name="UpdatePanel" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="UpdateStatusText" Text="Завантаження оновлення..." Foreground="#2980B9" FontWeight="Bold" VerticalAlignment="Center"/>
            <ProgressBar x:Name="UpdateProgressBar" Grid.Column="1" Margin="15,0" Height="15" Value="0" Maximum="100" Foreground="#2980B9" Background="#E0E6ED" BorderThickness="0"/>
            <TextBlock x:Name="UpdatePercentageText" Grid.Column="2" Text="0%" Foreground="#2980B9" FontWeight="Bold" VerticalAlignment="Center" Width="40" TextAlignment="Right"/>
        </Grid>

        <!-- Footer / Version Info -->
        <Grid Grid.Row="5" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="VersionText" Text="Версія: " Foreground="#95A5A6" VerticalAlignment="Center"/>
            <Button Grid.Column="2" Content="Перевірити оновлення" Padding="10,5" Background="#ECF0F1" Foreground="#34495E" BorderThickness="0" Cursor="Hand" Click="CheckUpdatesButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#BDC3C7"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>
