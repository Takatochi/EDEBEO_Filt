<Window x:Class="EdeboCsvProcessor.Wpf.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Статистика" Height="750" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#F5F6F8"
        FontFamily="Segoe UI">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Статистика за вибраними заявами" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

        <!-- Extended Table based on User Request -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,20" BorderBrush="#E0E6ED" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Headers -->
                <Border BorderBrush="#E0E6ED" BorderThickness="0,0,0,1" Grid.ColumnSpan="3" Margin="0,0,0,10" Padding="0,0,0,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Показник" FontWeight="Bold" Foreground="#7F8C8D"/>
                        <TextBlock Grid.Column="1" Text="Всього" FontWeight="Bold" Foreground="#7F8C8D" TextAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="За поточний день" FontWeight="Bold" Foreground="#7F8C8D" TextAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Row 1: Applications -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Кількість заяв поданих абітурієнтами для вступу на кафедру" TextWrapping="Wrap" Margin="0,5"/>
                <TextBlock x:Name="TotalAppsText" Grid.Row="1" Grid.Column="1" Text="0" TextAlignment="Center" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,5"/>
                <TextBlock x:Name="TodayAppsText" Grid.Row="1" Grid.Column="2" Text="0" TextAlignment="Center" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,5"/>
                
                <!-- Row 2: Originals -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Кількість оригіналів документів, поданих абітурієнтами" TextWrapping="Wrap" Margin="0,5"/>
                <TextBlock x:Name="TotalOriginalsText" Grid.Row="2" Grid.Column="1" Text="0" TextAlignment="Center" FontWeight="SemiBold" Foreground="#2980B9" Margin="0,5"/>
                <TextBlock x:Name="TodayOriginalsText" Grid.Row="2" Grid.Column="2" Text="0" TextAlignment="Center" FontWeight="SemiBold" Foreground="#2980B9" Margin="0,5"/>

                <!-- Row 3: Contracts -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Кількість заключених договорів про навчання" TextWrapping="Wrap" Margin="0,5"/>
                <TextBlock x:Name="TotalContractsText" Grid.Row="3" Grid.Column="1" Text="0" TextAlignment="Center" FontWeight="SemiBold" Foreground="#27AE60" Margin="0,5"/>
                <TextBlock x:Name="TodayContractsText" Grid.Row="3" Grid.Column="2" Text="0" TextAlignment="Center" FontWeight="SemiBold" Foreground="#27AE60" Margin="0,5"/>

                <!-- Row 4: Contract Applications -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Кількість заяв поданих на контракт" TextWrapping="Wrap" Margin="0,5"/>
                <TextBlock x:Name="TotalContractAppsText" Grid.Row="4" Grid.Column="1" Text="0" TextAlignment="Center" FontWeight="SemiBold" Foreground="#F39C12" Margin="0,5"/>
                <TextBlock x:Name="TodayContractAppsText" Grid.Row="4" Grid.Column="2" Text="0" TextAlignment="Center" FontWeight="SemiBold" Foreground="#F39C12" Margin="0,5"/>
            </Grid>
        </Border>

        <!-- Priorities Cards -->
        <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,20">
            <Border Background="White" CornerRadius="8" Padding="15" Margin="5" BorderBrush="#E0E6ED" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Заяви з 1-м пріоритетом" Foreground="#7F8C8D" FontSize="14" TextWrapping="Wrap"/>
                    <TextBlock x:Name="Prio1Text" Text="0" Foreground="#E74C3C" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="8" Padding="15" Margin="5" BorderBrush="#E0E6ED" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Заяви з 2-м пріоритетом" Foreground="#7F8C8D" FontSize="14" TextWrapping="Wrap"/>
                    <TextBlock x:Name="Prio2Text" Text="0" Foreground="#E67E22" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="8" Padding="15" Margin="5" BorderBrush="#E0E6ED" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Заяви з 3-м пріоритетом" Foreground="#7F8C8D" FontSize="14" TextWrapping="Wrap"/>
                    <TextBlock x:Name="Prio3Text" Text="0" Foreground="#F1C40F" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Detailed Breakdown -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="8" Padding="15" Margin="5,0,10,0" BorderBrush="#E0E6ED" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="За статусами (Всього)" FontWeight="Bold" FontSize="16" Foreground="#2C3E50" Margin="0,0,0,10"/>
                    <ListBox x:Name="StatusList" Grid.Row="1" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Key}" TextWrapping="Wrap" Foreground="#34495E" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="Bold" Foreground="#2980B9"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15" Margin="10,0,5,0" BorderBrush="#E0E6ED" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="За спеціальностями (Всього)" FontWeight="Bold" FontSize="16" Foreground="#2C3E50" Margin="0,0,0,10"/>
                    <ListBox x:Name="ProposalList" Grid.Row="1" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Key}" TextWrapping="Wrap" Foreground="#34495E" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="Bold" Foreground="#27AE60"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
